# ============================================================
# Clinic Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ============================================================

PORT=3000
NODE_ENV=production

# Database — SQLite file path
DB_PATH=/opt/clinic-platform/data/clinic.db

# Videos — path to NFS mount or local folder
# Use local path until NFS is ready:  /opt/clinic-platform/videos
# Switch to NFS mount when ready:     /mnt/clinic-videos
VIDEO_DIR=/opt/clinic-platform/videos

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET

# Password hashing salt — generate with: openssl rand -hex 16
PW_SALT=REPLACE_WITH_RANDOM_SALT

# Pocket ID OIDC
OIDC_ISSUER=https://auth.santahouse.me
OIDC_CLIENT_ID=REPLACE_WITH_CLIENT_ID
OIDC_CLIENT_SECRET=REPLACE_WITH_CLIENT_SECRET
OIDC_REDIRECT_URI=https://clinic.santahouse.me/auth/callback
